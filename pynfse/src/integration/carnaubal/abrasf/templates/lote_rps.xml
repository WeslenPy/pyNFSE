<EnviarLoteRpsEnvio xmlns="http://ws.speedgov.com.br/enviar_lote_rps_envio_v1.xsd">
    <LoteRps xmlns="" Id="{{lote.id}}">
        <NumeroLote>{{lote.numero_lote}}</NumeroLote>
        <Cnpj>{{lote.cnpj}}</Cnpj>
        <InscricaoMunicipal>{{lote.inscricao_municipal}}</InscricaoMunicipal>
        <QuantidadeRps>{{lote.quantidade_rps}}</QuantidadeRps>
        <ListaRps>
            {% for rps in lote.lista_rps %}
                {% include 'rps.xml' with context %}
            {% endfor %}
        </ListaRps>
    </LoteRps>
</EnviarLoteRpsEnvio>
